APP_NAME="Acute Tourism"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the exact URL you open in the browser (include subfolders on XAMPP, e.g. http://localhost/tour/public).
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Use database or redis in production and run `php artisan queue:work` so mail and queued jobs are reliable.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail: "log" = storage/logs only. For SMTP set MAIL_MAILER=smtp and fill host/port/scheme (e.g. tls + 587, or smtps + 465).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SMTP production example (uncomment/adapt — many hosts use MAIL_SCHEME=tls MAIL_PORT=587 or MAIL_SCHEME=smtps MAIL_PORT=465):
# MAIL_MAILER=smtp
# MAIL_SCHEME=tls
# MAIL_HOST=smtp.your-provider.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=

# Dedicated inbox for staff copies (new inquiries, checkout started, payment received). If empty, uses Site Settings contact email.
# Admin users (is_admin) also get these emails; same address is only mailed once.
BOOKING_NOTIFICATIONS_EMAIL=

# Initial admin account created by AdminUserSeeder.
ADMIN_USER_EMAIL=admin@acutetourism.org
ADMIN_USER_PASSWORD=Admin@12345

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# N-Genius Online (Network International) — hosted checkout. Docs:
# https://www.network.ae/en/merchant-solutions/ecommerce-payments/n-genius-online
# https://www.network.ae/en/merchant-solutions/ecommerce-payments/developers
# Use a public HTTPS APP_URL so redirectUrl + /payments/network/callback work (ngrok for local).
NETWORK_PAYMENT_ENABLED=false
NETWORK_PAYMENT_BASE_URL=https://api-gateway.sandbox.ngenius-payments.com
# Live: https://api-gateway.ngenius-payments.com
NETWORK_PAYMENT_OUTLET_ID=
# Service account: you can use either:
# 1) separate UUIDs in NETWORK_PAYMENT_API_KEY + NETWORK_PAYMENT_API_SECRET, or
# 2) a single base64("api_key:api_secret") in NETWORK_PAYMENT_API_KEY (leave NETWORK_PAYMENT_API_SECRET empty).
NETWORK_PAYMENT_API_KEY=
NETWORK_PAYMENT_API_SECRET=
# Identity realm for access token (auto: sandbox base URL → ni, production → networkinternational). Override only if Network docs require it.
# NETWORK_PAYMENT_REALM=networkinternational
# Optional aliases (read if the NETWORK_PAYMENT_* key above is empty):
# NGENIUS_ENABLED=true
# NGENIUS_API_URL=https://api-gateway.ngenius-payments.com
# NGENIUS_OUTLET_REF=
# NGENIUS_API_KEY=
# NGENIUS_API_SECRET=
# NGENIUS_REALM=networkinternational
NETWORK_PAYMENT_CURRENCY=AED
# PURCHASE = capture now. AUTH = authorize only (capture in merchant portal if supported).
NETWORK_PAYMENT_ACTION=PURCHASE
# Production token request often uses an empty POST body (set true to force {"realmName":...}, e.g. odd sandbox setups).
# NETWORK_PAYMENT_IDENTITY_SEND_REALM_NAME=false
# Hosted paypage: match working Network/Postman payloads.
NETWORK_PAYMENT_SKIP_CONFIRMATION_PAGE=true
NETWORK_PAYMENT_PAYMENT_ATTEMPTS=3

# Webhook: POST https://your-domain/payments/network/webhook — header X-Network-Webhook-Secret: <this value>
# Portal: https://developer.network.global/apis/webhook
# Required in production (APP_ENV=production); use a long random secret. Monitor logs for network_payment_webhook.sync_failed.
NETWORK_PAYMENT_WEBHOOK_SECRET=
WHATSAPP_NOTIFICATIONS_ENABLED=false
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_FROM=
